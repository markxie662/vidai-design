#!/bin/bash
# VidAI 安全检查工具

VERSION="0.1.0"
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
WHITE='\033[1;37m'
NC='\033[0m'

CONFIG_DIR="$HOME/.vidai"
CONFIG_FILE="$CONFIG_DIR/config.json"

clear

printf "${CYAN}╔══════════════════════════════════════════════════════════════════╗${NC}\n"
printf "${CYAN}║${NC}              ${BOLD}${WHITE}VidAI 安全检查${NC}                         ${CYAN}║${NC}\n"
printf "${CYAN}║${NC}          API 配置安全性验证工具                              ${CYAN}║${NC}\n"
printf "${CYAN}╚══════════════════════════════════════════════════════════════════╝${NC}\n\n"

# 检查计数
issues=0
warnings=0

# 检查配置目录权限
printf "${CYAN}检查配置目录权限...${NC} "
if [ -d "$CONFIG_DIR" ]; then
    perms=$(stat -f "%Lp" "$CONFIG_DIR" 2>/dev/null || stat -c "%a" "$CONFIG_DIR" 2>/dev/null)
    if [ "$perms" = "700" ]; then
        printf "${GREEN}✓ 安全 (700)${NC}\n"
    else
        printf "${RED}✗ 不安全 ($perms)${NC}\n"
        printf "   正在修复...\n"
        chmod 700 "$CONFIG_DIR" 2>/dev/null && printf "   ${GREEN}✓ 已修复为 700${NC}\n" || printf "   ${RED}✗ 修复失败${NC}\n"
        ((issues++))
    fi
else
    printf "${YELLOW}○ 目录不存在${NC}\n"
    ((warnings++))
fi

# 检查配置文件权限
printf "${CYAN}检查配置文件权限...${NC} "
if [ -f "$CONFIG_FILE" ]; then
    perms=$(stat -f "%Lp" "$CONFIG_FILE" 2>/dev/null || stat -c "%a" "$CONFIG_FILE" 2>/dev/null)
    if [ "$perms" = "600" ]; then
        printf "${GREEN}✓ 安全 (600)${NC}\n"
    else
        printf "${RED}✗ 不安全 ($perms)${NC}\n"
        printf "   正在修复...\n"
        chmod 600 "$CONFIG_FILE" 2>/dev/null && printf "   ${GREEN}✓ 已修复为 600${NC}\n" || printf "   ${RED}✗ 修复失败${NC}\n"
        ((issues++))
    fi
else
    printf "${YELLOW}○ 文件不存在${NC}\n"
    ((warnings++))
fi

# 检查 API Key 是否暴露
printf "${CYAN}检查 API Key 暴露风险...${NC} "
exposed_in=$(grep -r "ark-[a-zA-Z0-9_]\{32,\}" ~/vidai/ 2>/dev/null | grep -v ".git/" | grep -v "node_modules/" | grep -v "vidai-security-check" | wc -l)
if [ "$exposed_in" -eq 0 ]; then
    printf "${GREEN}✓ 未发现暴露${NC}\n"
else
    printf "${RED}✗ 发现 $exposed_in 处潜在暴露${NC}\n"
    ((issues++))
fi

# 检查环境变量
printf "${CYAN}检查环境变量...${NC} "
if [ -n "$ARK_API_KEY" ]; then
    printf "${YELLOW}⚠ ARK_API_KEY 已设置${NC}\n"
    printf "   建议: 仅在测试时使用，生产环境请使用配置文件\n"
    ((warnings++))
else
    printf "${GREEN}✓ 未设置环境变量${NC}\n"
fi

# 检查 .gitignore
printf "${CYAN}检查 .gitignore 配置...${NC} "
if [ -f ~/vidai/.gitignore ]; then
    if grep -q "config/" ~/vidai/.gitignore && grep -q "*.json" ~/vidai/.gitignore; then
        printf "${GREEN}✓ 已配置${NC}\n"
    else
        printf "${YELLOW}⚠ 配置不完整${NC}\n"
        ((warnings++))
    fi
else
    printf "${RED}✗ .gitignore 不存在${NC}\n"
    ((issues++))
fi

# 检查 Git 历史
printf "${CYAN}检查 Git 历史记录...${NC} "
if cd ~/vidai 2>/dev/null; then
    api_in_history=$(git log --all --full-history --source -- "*config*.json" 2>/dev/null | wc -l)
    if [ "$api_in_history" -eq 0 ]; then
        printf "${GREEN}✓ 未发现敏感信息${NC}\n"
    else
        printf "${RED}✗ 可能包含配置文件历史${NC}\n"
        printf "   建议: 使用 git filter-branch 或 BFG Repo-Cleaner 清理历史\n"
        ((issues++))
    fi
else
    printf "${YELLOW}○ 非 Git 仓库${NC}\n"
fi

# 检查日志文件
printf "${CYAN}检查日志文件...${NC} "
logs_with_api=$(find ~/vidai/ -name "*.log" -type f 2>/dev/null | xargs grep -l "ark-" 2>/dev/null | wc -l)
if [ "$logs_with_api" -eq 0 ]; then
    printf "${GREEN}✓ 未发现敏感信息${NC}\n"
else
    printf "${RED}✗ 发现 $logs_with_api 个日志文件包含 API Key${NC}\n"
    printf "   建议: 删除或清理这些日志文件\n"
    ((issues++))
fi

# 显示总结
printf "\n"
printf "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
printf "${CYAN}安全检查完成${NC}\n"
printf "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n\n"

if [ $issues -eq 0 ] && [ $warnings -eq 0 ]; then
    printf "${GREEN}🎉 所有检查通过！配置安全。${NC}\n\n"
elif [ $issues -eq 0 ]; then
    printf "${YELLOW}⚠️  发现 $warnings 个警告，建议修复${NC}\n\n"
else
    printf "${RED}❌ 发现 $issues 个安全问题，$warnings 个警告${NC}\n"
    printf "${RED}请立即修复安全问题！${NC}\n\n"
fi

# 显示安全建议
if [ $issues -gt 0 ] || [ $warnings -gt 0 ]; then
    printf "${CYAN}💡 安全建议：${NC}\n\n"
    printf "  1. 定期更换 API Key\n"
    printf "  2. 不要在代码中硬编码 API Key\n"
    printf "  3. 使用环境变量或配置文件\n"
    printf "  4. 确保配置文件权限为 600\n"
    printf "  5. 不要提交配置文件到 Git\n"
    printf "  6. 定期运行安全检查: ${CYAN}vidai-security-check${NC}\n\n"
fi

exit $issues
