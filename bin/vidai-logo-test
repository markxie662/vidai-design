    printf "${GRAY}в”Ӯ${NC}                   ${MAGENTA}в•°в•®           в•ӯв•Ҝ${NC}  ${CYAN}AI Video Creation${NC}    ${GRAY}в”Ӯ${NC}\n"
    printf "${GRAY}в”Ӯ${NC}                    ${MAGENTA}в•°в•®         в•ӯв•Ҝ${NC}                        ${GRAY}в”Ӯ${NC}\n"
