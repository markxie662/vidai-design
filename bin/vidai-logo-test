    printf "${GRAY}в”Ӯ${NC}                   ${CYAN}еӣҫзүҮ  и§Ҷйў‘  дјҳеҢ–${NC}                       ${GRAY}в”Ӯ${NC}\n"
    printf "${GRAY}в”Ӯ${NC}                   ${WHITE}в”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҖўв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}                         ${GRAY}в”Ӯ${NC}\n"
