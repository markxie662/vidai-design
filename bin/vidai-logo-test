#!/bin/bash

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
BOLD='\033[1m'
NC='\033[0m'

VERSION="0.1.0"

show_logo_1() {
    clear
    printf "\n"
    printf "${CYAN}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                                                          ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                    ${MAGENTA}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${NC}                          ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                   ${MAGENTA}в•ӯв•Ҝ        в•°в•®${NC}                         ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                  ${MAGENTA}в•ӯв•Ҝ          в•°в•®${NC}   ${WHITE}VidAI Design${NC}          ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                 ${MAGENTA}в•ӯв•Ҝ    в–“в–“в–“     в•°в•®${NC}  ${GREEN}%s${NC}                ${CYAN}в”Ӯ${NC}\n" "$VERSION"
    printf "${CYAN}в”Ӯ${NC}                 ${MAGENTA}в•°в•®          в•ӯв•Ҝ${NC}в”Җ                         ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                  ${MAGENTA}в•°в•®        в•ӯв•Ҝ${NC}   ${CYAN}AI Video Creation${NC}       ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                    ${MAGENTA}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${NC}                            ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                                                          ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                  ${WHITE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҖўв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}                        ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                  ${CYAN}еӣҫзүҮ${NC}  в”Ӯ  ${MAGENTA}и§Ҷйў‘${NC}  в”Ӯ  ${YELLOW}дјҳеҢ–${NC}                 ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                  ${WHITE}в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҖвҖўв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ${NC}                        ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в”Ӯ${NC}                                                          ${CYAN}в”Ӯ${NC}\n"
    printf "${CYAN}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${NC}\n"
    printf "\n"
}

show_logo_2() {
    clear
    printf "\n"
    printf "${MAGENTA}в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${NC}\n"
    printf "${MAGENTA}в•‘${NC}                                                          ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                        ${CYAN}в—Ү${NC}                               ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                       ${CYAN}в—Ҳ в—Ҳ${NC}                              ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                      ${CYAN}в—Ҳ   в—Ҳ${NC}        ${WHITE}VidAI Design${NC}         ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                     ${CYAN}в—Ҳ в–“в–“в–“ в—Ҳ${NC}       ${GREEN}%s${NC}               ${MAGENTA}в•‘${NC}\n" "$VERSION"
    printf "${MAGENTA}в•‘${NC}                      ${CYAN}в—Ҳ   в—Ҳ${NC}       ${CYAN}AI Video Creation${NC}     ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                       ${CYAN}в—Ҳ в—Ҳ${NC}                              ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                        ${CYAN}в—Ү${NC}                               ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                                                          ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                    ${WHITE}в”Җв”Җв”Җв”Җв”ҖвҖўв”Җв”Җв”Җв”Җв”Җ${NC}                          ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                    ${CYAN}еӣҫзүҮв”Ӯи§Ҷйў‘в”ӮдјҳеҢ–${NC}                       ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                    ${WHITE}в”Җв”Җв”Җв”Җв”ҖвҖўв”Җв”Җв”Җв”Җв”Җ${NC}                          ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•‘${NC}                                                          ${MAGENTA}в•‘${NC}\n"
    printf "${MAGENTA}в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${NC}\n"
    printf "\n"
}

