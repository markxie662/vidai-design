    printf "\n"
}

# дё»еҫӘзҺҜ
index=0

while true; do
    case $index in
        0) show_logo_1 ;;
        1) show_logo_2 ;;
        2) show_logo_3 ;;
        3) show_logo_4 ;;
    esac

    printf "${GRAY}жҢү Enter жҹҘзңӢдёӢдёҖдёӘ (1/2/3/4/q): ${NC}"
    read -r choice

    if [ "$choice" = "q" ]; then
        clear
        printf "\n${GREEN}  ж„ҹи°ўйў„и§ҲпјҒ${NC}\n\n"
        exit 0
    fi

    if [ -n "$choice" ] && [ "$choice" -ge 1 ] && [ "$choice" -le 4 ]; then
        index=$((choice - 1))
    else
        index=$(( (index + 1) % 4 ))
    fi
done
