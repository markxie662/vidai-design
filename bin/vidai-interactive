#\!/bin/bash
VERSION="0.1.0-interactive"
SEEDREAM_SKILL="$HOME/.claude/skills/byted-ark-seedream-skill/scripts/generate.js"
SEEDANCE_SKILL="$HOME/.claude/skills/byted-ark-seedance-skill/scripts/seedance-wrapper.js"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
BOLD='\033[1m'
NC='\033[0m'

get_cols() {
    tput cols 2>/dev/null || echo 80
}

show_banner() {
    clear
    local cols=$(get_cols)

    printf "\n"
    printf "${MAGENTA}╔"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╗${NC}\n"

    printf "${MAGENTA}║${NC}  ${BOLD}${WHITE}              vidai design${NC}              ${GREEN}v%s${NC}\n" "$VERSION"
    printf "${MAGENTA}║${NC}\n"

    local subtitle="✨ AI-Powered Video Creation Tool ✨"
    local padding=$(((cols - ${#subtitle}) / 2))
    printf "${MAGENTA}║${NC}"
    printf "%*s" $padding ""
    printf "${BOLD}${YELLOW}%s${NC}\n" "$subtitle"
    printf "${MAGENTA}║${NC}\n"

    printf "${MAGENTA}╠"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╣${NC}\n"

    printf "${MAGENTA}║${NC}  ${BOLD}${CYAN}▸ 功能特性${NC}\n"
    printf "${MAGENTA}║${NC}    ${CYAN}⚡${NC} 智能图片生成    ${YELLOW}⚡${NC} 专业视频创作    ${MAGENTA}💎${NC} Prompt优化\n"
    printf "${MAGENTA}║${NC}\n"

    printf "${MAGENTA}║${NC}  ${BOLD}${GREEN}▸ 快速开始${NC}\n"
    printf "${MAGENTA}║${NC}    ${GRAY}•${NC} ${WHITE}生成图片${NC} [描述]    ${GREEN}→${NC} ${GREEN}生成图片 森林精灵${NC}\n"
    printf "${MAGENTA}║${NC}    ${GRAY}•${NC} ${WHITE}生成视频${NC} [描述] [图] ${GREEN}→${NC} ${GREEN}生成视频 飞舞 fairy.png${NC}\n"
    printf "${MAGENTA}║${NC}    ${GRAY}•${NC} ${WHITE}优化${NC} [prompt]      ${GREEN}→${NC} ${GREEN}优化 森林精灵${NC}\n"
    printf "${MAGENTA}║${NC}\n"

    printf "${MAGENTA}╚"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╝${NC}\n"

    local help_text="💡 输入 ${BOLD}/help${NC} 查看所有命令 / 输入 ${BOLD}/exit${NC} 退出"
    local padding=$(((cols - 40) / 2))
    printf "%*s${help_text}\n\n" $padding ""
}

process_input() {
    local input="$1"
    input=$(echo "$input" | xargs)

    case "$input" in
        exit|quit|q)
            clear
            printf "\n${GREEN}  感谢使用 vidai design！期待下次相见 👋${NC}\n\n"
            exit 0
            ;;
        help|h|\?)
            show_help
            ;;
        clear|cls)
            show_banner
            ;;
        *图片*|*image*|*画*|*图*)
            handle_image "$input"
            ;;
        *视频*|*video*)
            handle_video "$input"
            ;;
        *优化*|*prompt*)
            handle_optimize "$input"
            ;;
        status)
            show_status
            ;;
        *)
            handle_unknown "$input"
            ;;
    esac
}

show_help() {
    local cols=$(get_cols)
    printf "\n"
    printf "${CYAN}╔"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╗${NC}\n"
    printf "${CYAN}║${NC}  ${BOLD}${WHITE}📚 命令帮助${NC}"
    local padding=$((cols - 14))
    printf "%*s" $padding ""
    printf "${CYAN}║${NC}\n"
    printf "${CYAN}╠"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╣${NC}\n"
    printf "${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}  ${BOLD}${GREEN}基础命令${NC}\n"
    printf "${CYAN}║${NC}    ${YELLOW}help${NC} - 显示帮助\n"
    printf "${CYAN}║${NC}    ${YELLOW}clear${NC} - 清屏\n"
    printf "${CYAN}║${NC}    ${YELLOW}status${NC} - 查看状态\n"
    printf "${CYAN}║${NC}    ${YELLOW}exit${NC} - 退出\n"
    printf "${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}  ${BOLD}${GREEN}功能命令${NC}\n"
    printf "${CYAN}║${NC}    ${YELLOW}生成图片 [描述]${NC}\n"
    printf "${CYAN}║${NC}    ${YELLOW}生成视频 [描述] [图片]${NC}\n"
    printf "${CYAN}║${NC}    ${YELLOW}优化 [prompt]${NC}\n"
    printf "${CYAN}║${NC}\n"
    printf "${CYAN}╚"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╝${NC}\n"
    printf "\n"
}

show_status() {
    local cols=$(get_cols)
    printf "\n"
    printf "${MAGENTA}╔"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╗${NC}\n"
    printf "${MAGENTA}║${NC}  ${BOLD}${WHITE}🔧 系统状态${NC}"
    local padding=$((cols - 14))
    printf "%*s" $padding ""
    printf "${MAGENTA}║${NC}\n"
    printf "${MAGENTA}╠"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╣${NC}\n"
    printf "${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}  ${BOLD}vidai design${NC} ${GREEN}%s${NC}\n" "$VERSION"
    if [ -f "$SEEDREAM_SKILL" ]; then
        printf "${MAGENTA}║${NC}  ${GREEN}✓${NC} Seedream\n"
    else
        printf "${MAGENTA}║${NC}  ${RED}✗${NC} Seedream\n"
    fi
    if [ -f "$SEEDANCE_SKILL" ]; then
        printf "${MAGENTA}║${NC}  ${GREEN}✓${NC} Seedance\n"
    else
        printf "${MAGENTA}║${NC}  ${RED}✗${NC} Seedance\n"
    fi
    printf "${MAGENTA}║${NC}\n"
    printf "${MAGENTA}╚"
    printf "%.*s" $((cols - 2)) "$(printf "═%.0s" {1..100})"
    printf "╝${NC}\n"
    printf "\n"
}

handle_image() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成图片|图片|image|画|画图|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\n${YELLOW}⚠️  请描述你想要生成的图片${NC}\n\n"
        return
    fi

    printf "\n${CYAN}🎨 生成图片${NC}\n"
    printf "${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
    printf "${BOLD}描述:${NC} ${GREEN}%s${NC}\n\n" "$prompt"
    printf "${YELLOW}⏳ 正在生成...${NC}\n\n"

    if [ \! -f "$SEEDREAM_SKILL" ]; then
        printf "${RED}❌ 未找到 Seedream skill${NC}\n\n"
        return
    fi

    node "$SEEDREAM_SKILL" --prompt "$prompt" --size "2K" --mode "text-to-image" --watermark false --optimize true --response_format "png" 2>&1

    printf "\n${GREEN}✅ 完成！${NC}\n\n"
}

handle_video() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成视频|视频|video|:|：)//g' | xargs)
    local image=$(echo "$input" | grep -oE '[^ ]+\.(png|jpg|jpeg)' | head -1)

    if [ -z "$prompt" ] || [ -z "$image" ]; then
        printf "\n${YELLOW}⚠️  请提供描述和图片路径${NC}\n\n"
        return
    fi

    printf "\n${MAGENTA}🎬 生成视频${NC}\n"
    printf "${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
    printf "${BOLD}描述:${NC} ${GREEN}%s${NC}\n" "$prompt"
    printf "${BOLD}图片:${NC} ${GRAY}%s${NC}\n\n" "$image"
    printf "${YELLOW}⏳ 正在生成...${NC}\n\n"

    if [ \! -f "$SEEDANCE_SKILL" ]; then
        printf "${RED}❌ 未找到 Seedance skill${NC}\n\n"
        return
    fi

    if [ \! -f "$image" ]; then
        printf "${RED}❌ 图片不存在${NC}\n\n"
        return
    fi

    node "$SEEDANCE_SKILL" create --prompt "$prompt" --image-file "$image" --duration 5 --ratio "16:9" --resolution "720p" --generate-audio false --watermark false --return-last-frame true 2>&1

    printf "\n${GREEN}✅ 完成！${NC}\n\n"
}

handle_optimize() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(优化|prompt|提示词|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\n${YELLOW}⚠️  请提供需要优化的描述${NC}\n\n"
        return
    fi

    printf "\n${CYAN}💡 Prompt 优化${NC}\n"
    printf "${GRAY}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
    printf "${BOLD}原始:${NC} ${GRAY}%s${NC}\n\n" "$prompt"
    printf "${BOLD}优化:${NC}\n"
    printf "${GREEN}close-up shot, slow dolly in, %s, cinematic lighting, 4K${NC}\n\n" "$prompt"
    printf "${BOLD}建议:${NC}\n"
    printf "  镜头: close-up / medium / wide\n"
    printf "  运镜: dolly in / pull back / pan\n"
    printf "  光影: cinematic / natural light\n"
    printf "  质量: 4K / ultra detailed\n\n"
}

handle_unknown() {
    local input="$1"
    printf "\n${YELLOW}🤔 我不太理解: ${WHITE}%s${NC}\n\n" "$input"
    printf "${BOLD}我可以帮你:${NC}\n"
    printf "  ${GREEN}生成图片${NC} - 生成图片 [描述]\n"
    printf "  ${GREEN}生成视频${NC} - 生成视频 [描述] [图片]\n"
    printf "  ${GREEN}优化描述${NC} - 优化 [描述]\n"
    printf "  ${GREEN}查看帮助${NC} - help\n\n"
}

main() {
    show_banner

    while true; do
        printf "${GREEN}►${NC} "
        read -r input

        if [ -n "$input" ]; then
            process_input "$input"
        fi
    done
}

main
