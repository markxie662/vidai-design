handle_image() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(ç”ںوˆگه›¾ç‰‡|ه›¾ç‰‡|image|ç”»|ç”»ه›¾|:|ï¼ڑ)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\r${CYAN}${BOLD}${RED}â–¶${NC} ${RED}âœ— è¯·وڈڈè؟°ن½ وƒ³è¦پç”ںوˆگçڑ„ه›¾ç‰‡${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
        return
    fi

    printf "\n${CYAN}â”Œâ”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”گ${NC}\n"
    printf "${CYAN}â”‚${NC} ${CYAN}â—ˆ ه›¾ç‰‡ç”ںوˆگن»»هٹ،${NC}                                                ${CYAN}â”‚${NC}\n"
    printf "${CYAN}â”œâ”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”¤${NC}\n"
    printf "${CYAN}â”‚${NC}  ${WHITE}Prompt:${NC} ${GREEN}%s${NC} %s" "$prompt"
    # Get prompt length for padding
    local prompt_len=${#prompt}
    local padding=$((69 - prompt_len - 10))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${CYAN}â”‚${NC}\n"
    printf "${CYAN}â”‚${NC}  ${WHITE}Mode:${NC}    ${CYAN}text-to-image${NC}                                        ${CYAN}â”‚${NC}\n"
    printf "${CYAN}â”‚${NC}  ${WHITE}Size:${NC}    ${CYAN}2K${NC}                                                       ${CYAN}â”‚${NC}\n"
    printf "${CYAN}â””â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”ک${NC}\n"

    printf "\n${YELLOW}âڈ³${NC} و­£هœ¨è°ƒç”¨ Seedream API...\n\n"

    if [ \! -f "$SEEDREAM_SKILL" ]; then
        printf "${RED}âœ— Seedream skill وœھه®‰è£…${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
        return
    fi

    node "$SEEDREAM_SKILL" --prompt "$prompt" --size "2K" --mode "text-to-image" --watermark false --optimize true --response_format "png" 2>&1

    printf "\n${GREEN}âœ“ ه›¾ç‰‡ç”ںوˆگه®Œوˆگï¼پ${NC}\n\n"
    printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
}

handle_video() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(ç”ںوˆگè§†é¢‘|è§†é¢‘|video|:|ï¼ڑ)//g' | xargs)
    local image=$(echo "$input" | grep -oE '[^ ]+\.(png|jpg|jpeg)' | head -1)

    if [ -z "$prompt" ] || [ -z "$image" ]; then
        printf "\r${CYAN}${BOLD}${RED}â–¶${NC} ${RED}âœ— è¯·وڈگن¾›وڈڈè؟°ه’Œه›¾ç‰‡è·¯ه¾„${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
        return
    fi

    printf "\n${MAGENTA}â”Œâ”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”گ${NC}\n"
    printf "${MAGENTA}â”‚${NC} ${MAGENTA}â—ˆ è§†é¢‘ç”ںوˆگن»»هٹ،${NC}                                                ${MAGENTA}â”‚${NC}\n"
    printf "${MAGENTA}â”œâ”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”¤${NC}\n"
    printf "${MAGENTA}â”‚${NC}  ${WHITE}Prompt:${NC}  ${GREEN}%s${NC} %s" "$prompt"
    local prompt_len=${#prompt}
    local padding=$((69 - prompt_len - 10))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${MAGENTA}â”‚${NC}\n"
    printf "${MAGENTA}â”‚${NC}  ${WHITE}Image:${NC}   ${CYAN}%s${NC} %s" "$image"
    local image_len=${#image}
    local padding=$((69 - image_len - 10))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${MAGENTA}â”‚${NC}\n"
    printf "${MAGENTA}â”‚${NC}  ${WHITE}Duration:${NC} ${CYAN}5s${NC}                                                      ${MAGENTA}â”‚${NC}\n"
    printf "${MAGENTA}â”‚${NC}  ${WHITE}Ratio:${NC}    ${CYAN}16:9${NC}                                                    ${MAGENTA}â”‚${NC}\n"
    printf "${MAGENTA}â””â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”ک${NC}\n"

    printf "\n${YELLOW}âڈ³${NC} و­£هœ¨è°ƒç”¨ Seedance API...\n\n"

    if [ \! -f "$SEEDANCE_SKILL" ]; then
        printf "${RED}âœ— Seedance skill وœھه®‰è£…${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
        return
    fi

    if [ \! -f "$image" ]; then
        printf "${RED}âœ— ه›¾ç‰‡و–‡ن»¶ن¸چه­کهœ¨: ${NC}%s\n\n" "$image"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
        return
    fi

    node "$SEEDANCE_SKILL" create --prompt "$prompt" --image-file "$image" --duration 5 --ratio "16:9" --resolution "720p" --generate-audio false --watermark false --return-last-frame true 2>&1

    printf "\n${GREEN}âœ“ è§†é¢‘ç”ںوˆگه®Œوˆگï¼پ${NC}\n\n"
    printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
}

handle_optimize() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(ن¼کهŒ–|prompt|وڈگç¤؛è¯چ|:|ï¼ڑ)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\r${CYAN}${BOLD}${RED}â–¶${NC} ${RED}âœ— è¯·وڈگن¾›éœ€è¦پن¼کهŒ–çڑ„وڈڈè؟°${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
        return
    fi

    printf "\n${YELLOW}â”Œâ”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”گ${NC}\n"
    printf "${YELLOW}â”‚${NC} ${YELLOW}â—ˆ Prompt ن¼کهŒ–${NC}                                                   ${YELLOW}â”‚${NC}\n"
