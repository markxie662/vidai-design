#\!/bin/bash
VERSION="0.1.0-interactive"
SEEDREAM_SKILL="$HOME/.claude/skills/byted-ark-seedream-skill/scripts/generate.js"
SEEDANCE_SKILL="$HOME/.claude/skills/byted-ark-seedance-skill/scripts/seedance-wrapper.js"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Animation delay for effects
ANIMATION_DELAY=0.05

# Blinking text effect
blink_text() {
    local text="$1"
    local color="$2"
    for i in {1..2}; do
        printf "\r${color}%s${NC}" "$text"
        sleep 0.3
        printf "\r${text//?/ }"
        sleep 0.1
    done
    printf "\r${color}%s${NC}\n" "$text"
}

