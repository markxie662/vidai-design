    printf "${CYAN}║${NC}                        ${BOLD}${WHITE}命令参考手册${NC}                        ${CYAN}║${NC}\n"
    printf "${CYAN}╠══════════════════════════════════════════════════════════════════════════════╣${NC}\n"
    printf "${CYAN}║${NC}                                                              ${CYAN}║${NC}\n"

    printf "${CYAN}║${NC}  ${GREEN}┌─ 系统命令 ──────────────────────────────────────────${NC}    ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}  ${GREEN}│${NC}                                                          ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}  ${GREEN}│${NC}  ${BOLD}/help${NC}     ${GRAY}→${NC}  显示此帮助信息                              ${CYAN}║${NC}\n"
