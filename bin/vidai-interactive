show_status() {
    clear

    printf "\n${CYAN}╔══════════════════════════════════════════════════════════════════════════════╗${NC}\n"
    printf "${CYAN}║${NC}                          ${BOLD}${WHITE}系统状态面板${NC}                           ${CYAN}║${NC}\n"
    printf "${CYAN}╠══════════════════════════════════════════════════════════════════════════════╣${NC}\n"
    printf "${CYAN}║${NC}                                                              ${CYAN}║${NC}\n"

    # Version info
    printf "${CYAN}║${NC}  ${BOLD}版本${NC}                                                        ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}    ${GREEN}%s${NC}                                                   ${CYAN}║${NC}\n" "$VERSION"
    printf "${CYAN}║${NC}                                                              ${CYAN}║${NC}\n"

    # Skills status
    printf "${CYAN}║${NC}  ${BOLD}已安装 Skills${NC}                                               ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}                                                              ${CYAN}║${NC}\n"

    printf "${CYAN}║${NC}  "
    if [ -f "$SEEDREAM_SKILL" ]; then
        printf "${GREEN}●${NC} ${CYAN}Seedream${NC}      ${GREEN}[✓ 已安装]${NC}                         ${CYAN}║${NC}\n"
    else
        printf "${RED}●${NC} ${CYAN}Seedream${NC}      ${RED}[✗ 未安装]${NC}                         ${CYAN}║${NC}\n"
    fi

    printf "${CYAN}║${NC}  "
    if [ -f "$SEEDANCE_SKILL" ]; then
        printf "${MAGENTA}●${NC} ${MAGENTA}Seedance${NC}      ${GREEN}[✓ 已安装]${NC}                         ${CYAN}║${NC}\n"
    else
        printf "${RED}●${NC} ${MAGENTA}Seedance${NC}      ${RED}[✗ 未安装]${NC}                         ${CYAN}║${NC}\n"
    fi

    printf "${CYAN}║${NC}                                                              ${CYAN}║${NC}\n"

    # System info
    printf "${CYAN}║${NC}  ${BOLD}系统信息${NC}                                                    ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}    ${GRAY}时间:${NC} $(date '+%Y-%m-%d %H:%M:%S')                            ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}    ${GRAY}用户:${NC} $USER                                                ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}                                                              ${CYAN}║${NC}\n"

    printf "${CYAN}╚══════════════════════════════════════════════════════════════════════════════╝${NC}\n\n"

    printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
}

handle_image() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成图片|图片|image|画|画图|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\r${CYAN}${BOLD}${RED}▶${NC} ${RED}✗ 请描述你想要生成的图片${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
        return
    fi

    printf "\n${CYAN}┌────────────────────────────────────────────────────────────────────────┐${NC}\n"
    printf "${CYAN}│${NC} ${CYAN}◈ 图片生成任务${NC}                                                ${CYAN}│${NC}\n"
    printf "${CYAN}├────────────────────────────────────────────────────────────────────────┤${NC}\n"
    printf "${CYAN}│${NC}  ${WHITE}Prompt:${NC} ${GREEN}%s${NC} %s" "$prompt"
    # Get prompt length for padding
    local prompt_len=${#prompt}
    local padding=$((69 - prompt_len - 10))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${CYAN}│${NC}\n"
    printf "${CYAN}│${NC}  ${WHITE}Mode:${NC}    ${CYAN}text-to-image${NC}                                        ${CYAN}│${NC}\n"
    printf "${CYAN}│${NC}  ${WHITE}Size:${NC}    ${CYAN}2K${NC}                                                       ${CYAN}│${NC}\n"
    printf "${CYAN}└────────────────────────────────────────────────────────────────────────┘${NC}\n"

    printf "\n${YELLOW}⏳${NC} 正在调用 Seedream API...\n\n"

    if [ \! -f "$SEEDREAM_SKILL" ]; then
        printf "${RED}✗ Seedream skill 未安装${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
        return
    fi

    node "$SEEDREAM_SKILL" --prompt "$prompt" --size "2K" --mode "text-to-image" --watermark false --optimize true --response_format "png" 2>&1

    printf "\n${GREEN}✓ 图片生成完成！${NC}\n\n"
    printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
}

handle_video() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成视频|视频|video|:|：)//g' | xargs)
    local image=$(echo "$input" | grep -oE '[^ ]+\.(png|jpg|jpeg)' | head -1)

    if [ -z "$prompt" ] || [ -z "$image" ]; then
        printf "\r${CYAN}${BOLD}${RED}▶${NC} ${RED}✗ 请提供描述和图片路径${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
        return
    fi

    printf "\n${MAGENTA}┌────────────────────────────────────────────────────────────────────────┐${NC}\n"
    printf "${MAGENTA}│${NC} ${MAGENTA}◈ 视频生成任务${NC}                                                ${MAGENTA}│${NC}\n"
    printf "${MAGENTA}├────────────────────────────────────────────────────────────────────────┤${NC}\n"
    printf "${MAGENTA}│${NC}  ${WHITE}Prompt:${NC}  ${GREEN}%s${NC} %s" "$prompt"
    local prompt_len=${#prompt}
    local padding=$((69 - prompt_len - 10))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${MAGENTA}│${NC}\n"
    printf "${MAGENTA}│${NC}  ${WHITE}Image:${NC}   ${CYAN}%s${NC} %s" "$image"
    local image_len=${#image}
    local padding=$((69 - image_len - 10))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${MAGENTA}│${NC}\n"
    printf "${MAGENTA}│${NC}  ${WHITE}Duration:${NC} ${CYAN}5s${NC}                                                      ${MAGENTA}│${NC}\n"
    printf "${MAGENTA}│${NC}  ${WHITE}Ratio:${NC}    ${CYAN}16:9${NC}                                                    ${MAGENTA}│${NC}\n"
    printf "${MAGENTA}└────────────────────────────────────────────────────────────────────────┘${NC}\n"

    printf "\n${YELLOW}⏳${NC} 正在调用 Seedance API...\n\n"

    if [ \! -f "$SEEDANCE_SKILL" ]; then
        printf "${RED}✗ Seedance skill 未安装${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
        return
    fi

    if [ \! -f "$image" ]; then
        printf "${RED}✗ 图片文件不存在: ${NC}%s\n\n" "$image"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
        return
    fi

    node "$SEEDANCE_SKILL" create --prompt "$prompt" --image-file "$image" --duration 5 --ratio "16:9" --resolution "720p" --generate-audio false --watermark false --return-last-frame true 2>&1

    printf "\n${GREEN}✓ 视频生成完成！${NC}\n\n"
    printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
}

handle_optimize() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(优化|prompt|提示词|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\r${CYAN}${BOLD}${RED}▶${NC} ${RED}✗ 请提供需要优化的描述${NC}\n\n"
        printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
        return
    fi

    printf "\n${YELLOW}┌────────────────────────────────────────────────────────────────────────┐${NC}\n"
    printf "${YELLOW}│${NC} ${YELLOW}◈ Prompt 优化${NC}                                                   ${YELLOW}│${NC}\n"
    printf "${YELLOW}├────────────────────────────────────────────────────────────────────────┤${NC}\n"
    printf "${YELLOW}│${NC}                                                              ${YELLOW}│${NC}\n"
    printf "${YELLOW}│${NC}  ${WHITE}原始描述:${NC}                                                   ${YELLOW}│${NC}\n"
    printf "${YELLOW}│${NC}  ${GRAY}%s${NC}" "$prompt"
    local prompt_len=${#prompt}
    local padding=$((62 - prompt_len))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${YELLOW}│${NC}\n"
    printf "${YELLOW}│${NC}                                                              ${YELLOW}│${NC}\n"
    printf "${YELLOW}│${NC}  ${GREEN}优化后:${NC}                                                      ${YELLOW}│${NC}\n"
    printf "${YELLOW}│${NC}  ${CYAN}close-up shot, slow dolly in,${NC}                             ${YELLOW}│${NC}\n"
    printf "${YELLOW}│${NC}  ${CYAN}%s, cinematic lighting, 4K${NC}" "$prompt"
    local prompt_len=${#prompt}
    local padding=$((62 - prompt_len - 28))
    for i in $(seq 1 $padding); do printf " "; done
    printf "${YELLOW}│${NC}\n"
    printf "${YELLOW}│${NC}                                                              ${YELLOW}│${NC}\n"
    printf "${YELLOW}└────────────────────────────────────────────────────────────────────────┘${NC}\n\n"

    printf "${WHITE}┌─ 专业建议 ──────────────────────────────────────────────────┐${NC}\n"
    printf "${WHITE}│${NC}  ${CYAN}镜头${NC}:  ${GRAY}close-up${NC} / ${GRAY}medium${NC} / ${GRAY}wide${NC}                               ${WHITE}│${NC}\n"
    printf "${WHITE}│${NC}  ${CYAN}运镜${NC}:  ${GRAY}dolly in${NC} / ${GRAY}pull back${NC} / ${GRAY}pan${NC}                            ${WHITE}│${NC}\n"
    printf "${WHITE}│${NC}  ${CYAN}光影${NC}:  ${GRAY}cinematic${NC} / ${GRAY}natural light${NC}                              ${WHITE}│${NC}\n"
    printf "${WHITE}│${NC}  ${CYAN}质量${NC}:  ${GRAY}4K${NC} / ${GRAY}ultra detailed${NC}                                 ${WHITE}│${NC}\n"
    printf "${WHITE}└────────────────────────────────────────────────────────────────────────┘${NC}\n\n"

    printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
}

handle_unknown() {
    local input="$1"
    printf "\r${CYAN}${BOLD}${RED}▶${NC} ${RED}✗ 未识别命令: ${GRAY}%s${NC}\n" "$input"

    printf "\n${GRAY}试试这些命令:${NC}\n"
    printf "  ${CYAN}▸${NC} ${GREEN}生成图片${NC} ${GRAY}[描述]${NC}\n"
    printf "  ${CYAN}▸${NC} ${MAGENTA}生成视频${NC} ${GRAY}[描述]${NC} ${CYAN}[图片]${NC}\n"
    printf "  ${CYAN}▸${NC} ${YELLOW}优化描述${NC} ${GRAY}[prompt]${NC}\n"
    printf "  ${CYAN}▸${NC} ${WHITE}/help${NC}\n\n"

    printf "${BOLD}${GREEN}${BOLD}${CYAN}▶${NC} "
}

main() {
    show_banner

    while true; do
        read -r input

        if [ -n "$input" ]; then
            # Move to beginning of line before processing
            printf "\r"
            process_input "$input"
        fi
    done
}

main
