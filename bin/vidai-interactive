process_input() {
    local input="$1"
    input=$(echo "$input" | xargs)

    case "$input" in
        exit|quit|q|/exit)
            clear
            printf "\n"
            printf "${CYAN}â•”â•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•—${NC}\n"
            printf "${CYAN}â•‘${NC}                                                                      ${CYAN}â•‘${NC}\n"
            printf "${CYAN}â•‘${NC}           ${GREEN}Thank you for using ${BOLD}${WHITE}VidAI${NC}${GREEN} Design${NC}!                      ${CYAN}â•‘${NC}\n"
            printf "${CYAN}â•‘${NC}                                                                      ${CYAN}â•‘${NC}\n"
            printf "${CYAN}â•‘${NC}                    ${MAGENTA}âœ¨${NC} See you next time ${MAGENTA}âœ¨${NC}                       ${CYAN}â•‘${NC}\n"
            printf "${CYAN}â•‘${NC}                                                                      ${CYAN}â•‘${NC}\n"
            printf "${CYAN}â•ڑâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•گâ•‌${NC}\n"
            printf "\n"
            exit 0
            ;;
        help|h|\?|/help)
            show_help
            ;;
        clear|cls|/clear)
            show_banner
            return
            ;;
        *ه›¾ç‰‡*|*image*|*ç”»*|*ه›¾*)
            handle_image "$input"
            ;;
        *è§†é¢‘*|*video*)
            handle_video "$input"
            ;;
        *ن¼کهŒ–*|*prompt*)
            handle_optimize "$input"
            ;;
        status|/status)
            show_status
            ;;
        *)
            handle_unknown "$input"
            ;;
    esac
}

