    printf "${CYAN}║${NC}  ${MAGENTA}│${NC}  ${WHITE}示例:${NC} ${GRAY}生成图片 森林精灵 穿着发光连衣裙${NC}                   ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}  ${MAGENTA}│${NC}                                                          ${CYAN}║${NC}\n"
    printf "${CYAN}║${NC}  ${MAGENTA}│${NC}  ${BOLD}生成视频 [描述] [图片]${NC}                              ${CYAN}║${NC}\n"
