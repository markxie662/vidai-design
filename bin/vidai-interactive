#\!/bin/bash
VERSION="0.1.0-interactive"
SEEDREAM_SKILL="$HOME/.claude/skills/byted-ark-seedream-skill/scripts/generate.js"
SEEDANCE_SKILL="$HOME/.claude/skills/byted-ark-seedance-skill/scripts/seedance-wrapper.js"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

show_banner() {
    clear

    printf "\n"
    printf "${BOLD}${WHITE}  vidai design${NC} ${GREEN}%s${NC}\n" "$VERSION"
    printf "${CYAN}  ─────────────────────────────────────────────${NC}\n"
    printf "${GRAY}  AI Video Creation Studio${NC}\n"
    printf "\n"
    printf "${CYAN}  ◆ 图片生成${NC}    ${MAGENTA}◆ 视频创作${NC}    ${YELLOW}◆ Prompt优化${NC}\n"
    printf "\n"
    printf "${GREEN}  快速开始:${NC}\n"
    printf "${GRAY}  ▸${NC} 生成图片 [描述]     ${CYAN}→${NC} 生成图片 森林中的精灵\n"
    printf "${GRAY}  ▸${NC} 生成视频 [描述]图   ${CYAN}→${NC} 生成视频 飞舞 fairy.png\n"
    printf "${GRAY}  ▸${NC} 优化描述 [prompt]   ${CYAN}→${NC} 优化 森林精灵\n"
    printf "\n"
    printf "${GRAY}  💡 输入 /help 查看所有命令 | /exit 退出${NC}\n\n"
}

process_input() {
    local input="$1"
    input=$(echo "$input" | xargs)

    case "$input" in
        exit|quit|q)
            clear
            printf "\n${GREEN}  感谢使用 vidai design！${NC}\n"
            printf "${GRAY}  期待下次相见 ✨${NC}\n\n"
            exit 0
            ;;
        help|h|\?|/help)
            show_help
            ;;
        clear|cls|/clear)
            show_banner
            ;;
        *图片*|*image*|*画*|*图*)
            handle_image "$input"
            ;;
        *视频*|*video*)
            handle_video "$input"
            ;;
        *优化*|*prompt*)
            handle_optimize "$input"
            ;;
        status|/status)
            show_status
            ;;
        *)
            handle_unknown "$input"
            ;;
    esac
}

show_help() {
    printf "\n"
    printf "${BOLD}${CYAN}  命令帮助${NC}\n"
    printf "${CYAN}  ────────────────────────────────────────${NC}\n\n"
    printf "${GREEN}  基础命令:${NC}\n"
    printf "    ${GREEN}/help${NC}     显示帮助信息\n"
    printf "    ${GREEN}/clear${NC}    清屏重绘界面\n"
    printf "    ${GREEN}/status${NC}   查看系统状态\n"
    printf "    ${GREEN}/exit${NC}     退出程序\n\n"
    printf "${CYAN}  功能命令:${NC}\n"
    printf "    ${YELLOW}生成图片${NC} [描述]         使用Seedream生成图片\n"
    printf "    ${YELLOW}生成视频${NC} [描述] [图片]  使用Seedance生成视频\n"
    printf "    ${YELLOW}优化描述${NC} [prompt]       优化提示词\n\n"
}

show_status() {
    printf "\n"
    printf "${BOLD}${MAGENTA}  系统状态${NC}\n"
    printf "${MAGENTA}  ────────────────────────────────────────${NC}\n\n"
    printf "  版本:     ${GREEN}%s${NC}\n" "$VERSION"
    printf "  Seedream: "
    if [ -f "$SEEDREAM_SKILL" ]; then
        printf "${GREEN}✓ 已安装${NC}\n"
    else
        printf "${RED}✗ 未安装${NC}\n"
    fi
    printf "  Seedance: "
    if [ -f "$SEEDANCE_SKILL" ]; then
        printf "${GREEN}✓ 已安装${NC}\n"
    else
        printf "${RED}✗ 未安装${NC}\n"
    fi
    printf "\n"
}

handle_image() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成图片|图片|image|画|画图|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\n${YELLOW}  ⚠ 请描述你想要生成的图片${NC}\n\n"
        return
    fi

    printf "\n${CYAN}  图片生成${NC}\n"
    printf "${CYAN}  ────────────────────────────────────────${NC}\n"
    printf "  描述: ${GREEN}%s${NC}\n" "$prompt"
    printf "  状态: ${YELLOW}正在生成...${NC}\n\n"

    if [ \! -f "$SEEDREAM_SKILL" ]; then
        printf "${RED}  ✗ 未找到 Seedream skill${NC}\n\n"
        return
    fi

    node "$SEEDREAM_SKILL" --prompt "$prompt" --size "2K" --mode "text-to-image" --watermark false --optimize true --response_format "png" 2>&1

    printf "\n${GREEN}  ✓ 生成完成！${NC}\n\n"
}

handle_video() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成视频|视频|video|:|：)//g' | xargs)
    local image=$(echo "$input" | grep -oE '[^ ]+\.(png|jpg|jpeg)' | head -1)

    if [ -z "$prompt" ] || [ -z "$image" ]; then
        printf "\n${YELLOW}  ⚠ 请提供描述和图片路径${NC}\n\n"
        return
    fi

    printf "\n${MAGENTA}  视频生成${NC}\n"
    printf "${MAGENTA}  ────────────────────────────────────────${NC}\n"
    printf "  描述: ${GREEN}%s${NC}\n" "$prompt"
    printf "  图片: ${GRAY}%s${NC}\n" "$image"
    printf "  状态: ${YELLOW}正在生成...${NC}\n\n"

    if [ \! -f "$SEEDANCE_SKILL" ]; then
        printf "${RED}  ✗ 未找到 Seedance skill${NC}\n\n"
        return
    fi

    if [ \! -f "$image" ]; then
        printf "${RED}  ✗ 图片文件不存在${NC}\n\n"
        return
    fi

    node "$SEEDANCE_SKILL" create --prompt "$prompt" --image-file "$image" --duration 5 --ratio "16:9" --resolution "720p" --generate-audio false --watermark false --return-last-frame true 2>&1

    printf "\n${GREEN}  ✓ 生成完成！${NC}\n\n"
}

handle_optimize() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(优化|prompt|提示词|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\n${YELLOW}  ⚠ 请提供需要优化的描述${NC}\n\n"
        return
    fi

    printf "\n${CYAN}  Prompt 优化${NC}\n"
    printf "${CYAN}  ────────────────────────────────────────${NC}\n"
    printf "  原始: ${GRAY}%s${NC}\n" "$prompt"
    printf "  优化: ${GREEN}close-up shot, slow dolly in, %s,${NC}\n" "$prompt"
    printf "        ${GREEN}cinematic lighting, 4K${NC}\n\n"
    printf "  建议:\n"
    printf "    镜头: close-up / medium / wide\n"
    printf "    运镜: dolly in / pull back / pan\n"
    printf "    光影: cinematic / natural light\n"
    printf "    质量: 4K / ultra detailed\n\n"
}

handle_unknown() {
    local input="$1"
    printf "\n${YELLOW}  未识别命令: ${GRAY}%s${NC}\n" "$input"
    printf "\n  试试这些:\n"
    printf "    ${CYAN}生成图片${NC} [描述]\n"
    printf "    ${MAGENTA}生成视频${NC} [描述] [图片]\n"
    printf "    ${YELLOW}优化描述${NC} [prompt]\n"
    printf "    ${GREEN}/help${NC} 查看帮助\n\n"
}

main() {
    show_banner

    while true; do
        printf "${GREEN}►${NC} "
        read -r input

        if [ -n "$input" ]; then
            process_input "$input"
        fi
    done
}

main
