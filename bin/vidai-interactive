}

process_input() {
    local input="$1"
    input=$(echo "$input" | xargs)

    case "$input" in
        exit|quit|q|/exit)
            clear
            printf "\n"
            printf "${CYAN}╔══════════════════════════════════════════════════════════════════════════════╗${NC}\n"
            printf "${CYAN}║${NC}                                                                      ${CYAN}║${NC}\n"
            printf "${CYAN}║${NC}           ${GREEN}Thank you for using ${BOLD}${WHITE}VidAI${NC}${GREEN} Design${NC}!                      ${CYAN}║${NC}\n"
            printf "${CYAN}║${NC}                                                                      ${CYAN}║${NC}\n"
            printf "${CYAN}║${NC}                    ${MAGENTA}✨${NC} See you next time ${MAGENTA}✨${NC}                       ${CYAN}║${NC}\n"
            printf "${CYAN}║${NC}                                                                      ${CYAN}║${NC}\n"
            printf "${CYAN}╚══════════════════════════════════════════════════════════════════════════════╝${NC}\n"
            printf "\n"
            exit 0
            ;;
        help|h|\?|/help)
            show_help
            ;;
        clear|cls|/clear)
            show_banner
            return
            ;;
        *图片*|*image*|*画*|*图*)
            handle_image "$input"
            ;;
        *视频*|*video*)
            handle_video "$input"
            ;;
        *优化*|*prompt*)
            handle_optimize "$input"
            ;;
        status|/status)
            show_status
            ;;
        *)
            handle_unknown "$input"
            ;;
    esac
}

