handle_unknown() {
    local input="$1"
    printf "\r${CYAN}${BOLD}${RED}â–¶${NC} ${RED}âœ— وœھè¯†هˆ«ه‘½ن»¤: ${GRAY}%s${NC}\n" "$input"

    printf "\n${GRAY}è¯•è¯•è؟™ن؛›ه‘½ن»¤:${NC}\n"
    printf "  ${CYAN}â–¸${NC} ${GREEN}ç”ںوˆگه›¾ç‰‡${NC} ${GRAY}[وڈڈè؟°]${NC}\n"
    printf "  ${CYAN}â–¸${NC} ${MAGENTA}ç”ںوˆگè§†é¢‘${NC} ${GRAY}[وڈڈè؟°]${NC} ${CYAN}[ه›¾ç‰‡]${NC}\n"
    printf "  ${CYAN}â–¸${NC} ${YELLOW}ن¼کهŒ–وڈڈè؟°${NC} ${GRAY}[prompt]${NC}\n"
    printf "  ${CYAN}â–¸${NC} ${WHITE}/help${NC}\n\n"

    printf "${BOLD}${GREEN}${BOLD}${CYAN}â–¶${NC} "
}

main() {
    show_banner

    while true; do
        read -r input

        if [ -n "$input" ]; then
            # Move to beginning of line before processing
            printf "\r"
            process_input "$input"
        fi
    done
}

main
