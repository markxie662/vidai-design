#\!/bin/bash
VERSION="0.1.0-interactive"
SEEDREAM_SKILL="$HOME/.claude/skills/byted-ark-seedream-skill/scripts/generate.js"
SEEDANCE_SKILL="$HOME/.claude/skills/byted-ark-seedance-skill/scripts/seedance-wrapper.js"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
GRAY='\033[0;37m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

show_banner() {
    clear

    printf "\n"
    printf "${MAGENTA}╔════════════════════════════════════════════════════════╗${NC}\n"
    printf "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                        ${CYAN}◇${NC}                               ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                       ${CYAN}◈ ◈${NC}                              ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                      ${CYAN}◈   ◈${NC}        ${WHITE}VidAI Design${NC}         ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                     ${CYAN}◈ ▓▓▓ ◈${NC}       ${GREEN}%s${NC}               ${MAGENTA}║${NC}\n" "$VERSION"
    printf "${MAGENTA}║${NC}                      ${CYAN}◈   ◈${NC}       ${CYAN}AI Video Creation${NC}     ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                       ${CYAN}◈ ◈${NC}                              ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                        ${CYAN}◇${NC}                               ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                    ${WHITE}─────•─────${NC}                          ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                    ${CYAN}图片│视频│优化${NC}                       ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                    ${WHITE}─────•─────${NC}                          ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}║${NC}                                                          ${MAGENTA}║${NC}\n"
    printf "${MAGENTA}╚════════════════════════════════════════════════════════╝${NC}\n"

    printf "\n${GREEN}  快速开始${NC}\n"
    printf "  ${GRAY}01.${NC} 生成图片 [描述]\n"
    printf "      ${CYAN}→${NC} 生成图片 森林中的精灵\n\n"
    printf "  ${GRAY}02.${NC} 生成视频 [描述] [图片]\n"
    printf "      ${CYAN}→${NC} 生成视频 飞舞 fairy.png\n\n"
    printf "  ${GRAY}03.${NC} 优化描述 [prompt]\n"
    printf "      ${CYAN}→${NC} 优化 森林精灵\n\n"

    printf "${GRAY}  ───────────────────────────────────────────${NC}\n"
    printf "${YELLOW}  💡${NC} /help 帮助  /exit 退出\n\n"
}

process_input() {
    local input="$1"
    input=$(echo "$input" | xargs)

    case "$input" in
        exit|quit|q)
            clear
            printf "\n"
            printf "${GREEN}  感谢使用 vidai design！${NC}\n"
            printf "${GRAY}  ───────────────────────────────────────────${NC}\n"
            printf "  ${GRAY}期待下次相见${NC} ${WHITE}✨${NC}\n\n"
            exit 0
            ;;
        help|h|\?|/help)
            show_help
            ;;
        clear|cls|/clear)
            show_banner
            ;;
        *图片*|*image*|*画*|*图*)
            handle_image "$input"
            ;;
        *视频*|*video*)
            handle_video "$input"
            ;;
        *优化*|*prompt*)
            handle_optimize "$input"
            ;;
        status|/status)
            show_status
            ;;
        *)
            handle_unknown "$input"
            ;;
    esac
}

show_help() {
    printf "\n"
    printf "${BOLD}${CYAN}  命令帮助${NC}\n"
    printf "${GRAY}  ───────────────────────────────────────────${NC}\n\n"

    printf "  ${GREEN}基础命令${NC}\n"
    printf "  ${GRAY}01.${NC} /help   显示帮助信息\n"
    printf "  ${GRAY}02.${NC} /clear  清屏重绘界面\n"
    printf "  ${GRAY}03.${NC} /status 查看系统状态\n"
    printf "  ${GRAY}04.${NC} /exit   退出程序\n\n"

    printf "  ${CYAN}功能命令${NC}\n"
    printf "  ${GRAY}01.${NC} 生成图片 [描述]\n"
    printf "  ${GRAY}02.${NC} 生成视频 [描述] [图片]\n"
    printf "  ${GRAY}03.${NC} 优化描述 [prompt]\n\n"

    printf "${GRAY}  ───────────────────────────────────────────${NC}\n\n"
}

show_status() {
    printf "\n"
    printf "${BOLD}${MAGENTA}  系统状态${NC}\n"
    printf "${GRAY}  ───────────────────────────────────────────${NC}\n\n"

    printf "  ${WHITE}版本${NC}      ${GREEN}%s${NC}\n" "$VERSION"

    printf "  ${CYAN}Seedream${NC}  "
    if [ -f "$SEEDREAM_SKILL" ]; then
        printf "${GREEN}✓ 已安装${NC}\n"
    else
        printf "${RED}✗ 未安装${NC}\n"
    fi

    printf "  ${MAGENTA}Seedance${NC}  "
    if [ -f "$SEEDANCE_SKILL" ]; then
        printf "${GREEN}✓ 已安装${NC}\n"
    else
        printf "${RED}✗ 未安装${NC}\n"
    fi

    printf "\n${GRAY}  ───────────────────────────────────────────${NC}\n\n"
}

handle_image() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成图片|图片|image|画|画图|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\n${YELLOW}  ⚠ 请描述你想要生成的图片${NC}\n\n"
        return
    fi

    printf "\n${CYAN}  图片生成${NC}\n"
    printf "${GRAY}  ───────────────────────────────────────────${NC}\n"
    printf "  ${WHITE}描述${NC}  ${GREEN}%s${NC}\n" "$prompt"
    printf "  ${YELLOW}⏳ 正在生成...${NC}\n\n"

    if [ \! -f "$SEEDREAM_SKILL" ]; then
        printf "${RED}  ✗ 未找到 Seedream skill${NC}\n\n"
        return
    fi

    node "$SEEDREAM_SKILL" --prompt "$prompt" --size "2K" --mode "text-to-image" --watermark false --optimize true --response_format "png" 2>&1

    printf "${GRAY}  ───────────────────────────────────────────${NC}\n"
    printf "${GREEN}  ✓ 生成完成${NC}\n\n"
}

handle_video() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(生成视频|视频|video|:|：)//g' | xargs)
    local image=$(echo "$input" | grep -oE '[^ ]+\.(png|jpg|jpeg)' | head -1)

    if [ -z "$prompt" ] || [ -z "$image" ]; then
        printf "\n${YELLOW}  ⚠ 请提供描述和图片路径${NC}\n\n"
        return
    fi

    printf "\n${MAGENTA}  视频生成${NC}\n"
    printf "${GRAY}  ───────────────────────────────────────────${NC}\n"
    printf "  ${WHITE}描述${NC}  ${GREEN}%s${NC}\n" "$prompt"
    printf "  ${WHITE}图片${NC}  ${GRAY}%s${NC}\n" "$image"
    printf "  ${YELLOW}⏳ 正在生成...${NC}\n\n"

    if [ \! -f "$SEEDANCE_SKILL" ]; then
        printf "${RED}  ✗ 未找到 Seedance skill${NC}\n\n"
        return
    fi

    if [ \! -f "$image" ]; then
        printf "${RED}  ✗ 图片文件不存在${NC}\n\n"
        return
    fi

    node "$SEEDANCE_SKILL" create --prompt "$prompt" --image-file "$image" --duration 5 --ratio "16:9" --resolution "720p" --generate-audio false --watermark false --return-last-frame true 2>&1

    printf "${GRAY}  ───────────────────────────────────────────${NC}\n"
    printf "${GREEN}  ✓ 生成完成${NC}\n\n"
}

handle_optimize() {
    local input="$1"
    local prompt=$(echo "$input" | sed -E 's/(优化|prompt|提示词|:|：)//g' | xargs)

    if [ -z "$prompt" ]; then
        printf "\n${YELLOW}  ⚠ 请提供需要优化的描述${NC}\n\n"
        return
    fi

    printf "\n${CYAN}  Prompt 优化${NC}\n"
    printf "${GRAY}  ───────────────────────────────────────────${NC}\n"

    printf "  ${WHITE}原始${NC}  ${GRAY}%s${NC}\n" "$prompt"
    printf "  ${WHITE}优化${NC}  ${GREEN}close-up shot, slow dolly in, %s,${NC}\n" "$prompt"
    printf "        ${GREEN}cinematic lighting, 4K${NC}\n\n"

    printf "  ${YELLOW}建议${NC}\n"
    printf "  ${GRAY}镜头${NC}  close-up / medium / wide\n"
    printf "  ${GRAY}运镜${NC}  dolly in / pull back / pan\n"
    printf "  ${GRAY}光影${NC}  cinematic / natural light\n"
    printf "  ${GRAY}质量${NC}  4K / ultra detailed\n\n"

    printf "${GRAY}  ───────────────────────────────────────────${NC}\n\n"
}

handle_unknown() {
    local input="$1"
    printf "\n${YELLOW}  未识别命令${NC}\n"
    printf "${GRAY}  ───────────────────────────────────────────${NC}\n"
    printf "  ${GRAY}%s${NC}\n\n" "$input"

    printf "  ${WHITE}试试这些${NC}\n"
    printf "  ${GRAY}01.${NC} 生成图片 [描述]\n"
    printf "  ${GRAY}02.${NC} 生成视频 [描述] [图片]\n"
    printf "  ${GRAY}03.${NC} 优化描述 [prompt]\n"
    printf "  ${GRAY}04.${NC} /help\n\n"

    printf "${GRAY}  ───────────────────────────────────────────${NC}\n\n"
}

main() {
    show_banner

    while true; do
        printf "${GREEN}►${NC} "
        read -r input

        if [ -n "$input" ]; then
            process_input "$input"
        fi
    done
}

main
