# Animation delay for effects
ANIMATION_DELAY=0.05

# Blinking text effect
blink_text() {
    local text="$1"
    local color="$2"
    for i in {1..2}; do
        printf "\r${color}%s${NC}" "$text"
        sleep 0.3
        printf "\r${text//?/ }"
        sleep 0.1
    done
    printf "\r${color}%s${NC}\n" "$text"
}

