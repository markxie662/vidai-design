#!/bin/bash
# VidAI 配置向导 - 方舟 Agent Plan API 配置

VERSION="0.1.0"
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
WHITE='\033[1;37m'
BOLD='\033[1m'
NC='\033[0m'

CONFIG_FILE="$HOME/.vidai/config.json"
CONFIG_DIR="$HOME/.vidai"

clear

printf "${CYAN}╔══════════════════════════════════════════════════════════════════╗${NC}\n"
printf "${CYAN}║${NC}              ${BOLD}${WHITE}VidAI 配置向导${NC}                         ${CYAN}║${NC}\n"
printf "${CYAN}║${NC}          方舟 Agent Plan API 配置工具                         ${CYAN}║${NC}\n"
printf "${CYAN}╚══════════════════════════════════════════════════════════════════╝${NC}\n\n"

# 检查现有配置
check_existing_config() {
    if [ -f "$CONFIG_FILE" ]; then
        local api_key=$(jq -r '.model.api_key // empty' "$CONFIG_FILE" 2>/dev/null)
        if [ -n "$api_key" ] && [ "$api_key" != "null" ] && [ "$api_key" != "" ]; then
            local masked_key="${api_key:0:8}...${api_key: -4}"
            printf "${GREEN}✓${NC} 已配置 API Key: ${YELLOW}%s${NC}\n\n" "$masked_key"
            return 0
        fi
    fi
    printf "${RED}✗${NC} 未配置 API Key\n\n"
    return 1
}

show_menu() {
    printf "${CYAN}请选择操作：${NC}\n\n"
    printf "  ${GREEN}1.${NC} 配置方舟 API Key\n"
    printf "  ${GREEN}2.${NC} 查看当前配置\n"
    printf "  ${GREEN}3.${NC} 测试 API 连接\n"
    printf "  ${GREEN}4.${NC} 删除配置\n"
    printf "  ${GREEN}5.${NC} 退出\n\n"
}

input_api_key() {
    printf "\n${CYAN}请输入方舟 Agent Plan API Key:${NC} "
    read -r api_key

    if [ -z "$api_key" ]; then
        printf "\n${RED}✗ API Key 不能为空${NC}\n\n"
        return 1
    fi

    if [[ ! "$api_key" =~ ^ark-[a-zA-Z0-9_]{32,}$ ]]; then
        printf "\n${YELLOW}⚠ API Key 格式可能不正确（应为 ark-xxx 格式）${NC}\n"
        printf "${YELLOW}是否继续？${NC} "
        read -r confirm
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            return 1
        fi
    fi

    # 创建配置目录
    mkdir -p "$CONFIG_DIR"

    # 创建配置文件
    cat > "$CONFIG_FILE" << EOF
{
  "model": {
    "provider": "volcengine",
    "api_key": "$api_key"
  },
  "seedream": {
    "enabled": true,
    "default_size": "2K",
    "default_mode": "text-to-image",
    "optimize": true,
    "watermark": false
  },
  "seedance": {
    "enabled": true,
    "default_duration": 5,
    "default_ratio": "16:9",
    "default_resolution": "720p",
    "generate_audio": false,
    "watermark": false
  }
}
EOF

    printf "\n${GREEN}✓ 配置已保存到: %s${NC}\n\n" "$CONFIG_FILE"
}

show_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        printf "\n${RED}✗ 配置文件不存在${NC}\n\n"
        return
    fi

    printf "\n${CYAN}当前配置：${NC}\n\n"
    printf "  配置文件: ${YELLOW}%s${NC}\n" "$CONFIG_FILE"

    local api_key=$(jq -r '.model.api_key // "未配置"' "$CONFIG_FILE")
    if [ "$api_key" != "未配置" ] && [ "$api_key" != "null" ] && [ -n "$api_key" ]; then
        local masked_key="${api_key:0:8}...${api_key: -4}"
        printf "  API Key:  ${GREEN}%s${NC}\n" "$masked_key"
    else
        printf "  API Key:  ${RED}未配置${NC}\n"
    fi

    local provider=$(jq -r '.model.provider // "未知"' "$CONFIG_FILE")
    printf "  提供商:  ${CYAN}%s${NC}\n" "$provider"

    local seedream_enabled=$(jq -r '.seedream.enabled // false' "$CONFIG_FILE")
    local seedance_enabled=$(jq -r '.seedance.enabled // false' "$CONFIG_FILE")

    printf "  Seedream: ${GREEN}%s${NC}\n" "$([ "$seedream_enabled" = "true" ] && echo "启用" || echo "禁用")"
    printf "  Seedance: ${GREEN}%s${NC}\n\n" "$([ "$seedance_enabled" = "true" ] && echo "启用" || echo "禁用")"
}

test_connection() {
    if [ ! -f "$CONFIG_FILE" ]; then
        printf "\n${RED}✗ 请先配置 API Key${NC}\n\n"
        return
    fi

    local api_key=$(jq -r '.model.api_key // empty' "$CONFIG_FILE")
    if [ -z "$api_key" ] || [ "$api_key" = "null" ]; then
        printf "\n${RED}✗ API Key 未配置${NC}\n\n"
        return
    fi

    printf "\n${YELLOW}⏳ 测试连接中...${NC}\n\n"

    # 测试连接到方舟 API
    local response=$(curl -s -X POST \
        "https://ark.cn-beijing.volces.com/api/v3/chat/completions" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $api_key" \
        -d '{
            "model": "ep-20250603171632-wzccv",
            "messages": [{"role": "user", "content": "Hi"}],
            "max_tokens": 10
        }' 2>&1)

    if echo "$response" | grep -q "error\|Error\|error_code"; then
        printf "${RED}✗ 连接失败${NC}\n\n"
        echo "响应: $response" | head -3
        printf "\n${YELLOW}请检查 API Key 是否正确${NC}\n\n"
    else
        printf "${GREEN}✓ 连接成功！API Key 有效${NC}\n\n"
    fi
}

delete_config() {
    if [ ! -f "$CONFIG_FILE" ]; then
        printf "\n${RED}✗ 配置文件不存在${NC}\n\n"
        return
    fi

    printf "\n${YELLOW}⚠ 确定要删除配置吗？${NC} "
    read -r confirm

    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        rm "$CONFIG_FILE"
        printf "\n${GREEN}✓ 配置已删除${NC}\n\n"
    else
        printf "\n${CYAN}已取消${NC}\n\n"
    fi
}

main() {
    check_existing_config

    while true; do
        show_menu
        printf "${CYAN}▶${NC} "
        read -r choice

        case $choice in
            1)
                input_api_key
                ;;
            2)
                show_config
                ;;
            3)
                test_connection
                ;;
            4)
                delete_config
                ;;
            5|q|quit|exit)
                printf "\n${GREEN}感谢使用 VidAI 配置向导！${NC}\n\n"
                exit 0
                ;;
            *)
                printf "\n${RED}无效选择，请重试${NC}\n\n"
                ;;
        esac

        if [ "$choice" != "5" ] && [ "$choice" != "q" ] && [ "$choice" != "quit" ] && [ "$choice" != "exit" ]; then
            printf "${YELLOW}按 Enter 继续...${NC} "
            read -r
            clear
            printf "${CYAN}╔══════════════════════════════════════════════════════════════════╗${NC}\n"
            printf "${CYAN}║${NC}              ${BOLD}${WHITE}VidAI 配置向导${NC}                         ${CYAN}║${NC}\n"
            printf "${CYAN}║${NC}          方舟 Agent Plan API 配置工具                         ${CYAN}║${NC}\n"
            printf "${CYAN}╚══════════════════════════════════════════════════════════════════╝${NC}\n\n"
            check_existing_config
        fi
    done
}

main
